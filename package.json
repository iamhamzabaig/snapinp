{
  "name": "snapinp",
  "version": "0.1.0",
  "description": "One line. Instant UI. Every interaction. Automatically optimizes Interaction to Next Paint (INP).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "size": "size-limit",
    "prepublishOnly": "npm run build",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run size"
  },
  "keywords": [
    "inp",
    "interaction-to-next-paint",
    "web-vitals",
    "performance",
    "core-web-vitals",
    "scheduler",
    "yield",
    "ux"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamhamzabaig/snapinp.git"
  },
  "homepage": "https://github.com/iamhamzabaig/snapinp#readme",
  "bugs": {
    "url": "https://github.com/iamhamzabaig/snapinp/issues"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.10",
    "@size-limit/preset-small-lib": "11.1.6",
    "@testing-library/dom": "10.4.0",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.17.0",
    "happy-dom": "15.11.7",
    "prettier": "3.4.2",
    "size-limit": "11.1.6",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "@vitest/coverage-v8": "2.1.8"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "3 KB",
      "gzip": true
    }
  ],
  "sideEffects": false
}
